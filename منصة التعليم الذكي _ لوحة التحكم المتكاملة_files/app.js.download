async function handleInventorySubmit(e) {
    e.preventDefault();
    const id = document.getElementById("editInventoryId").value;
    const item = document.getElementById("inventoryItem").value;
    const count = parseInt(document.getElementById("inventoryCount").value);
    const price = document.getElementById("inventoryPrice").value;
    const status = document.getElementById("inventoryStatus").value;

    const data = { id: id || "", item, count, price, status };

    try {
        const res = await fetch(`${API_BASE}/api/erp/inventory`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });
        appState.erpData = await res.json();
        recordActivityLog(id ? "تعديل بيانات كتاب" : "إضافة كتاب جديد للمخزن", item);
        closeModal("inventoryModal");
        renderERPTables();
    } catch (err) {
        console.error(err);
    }
}

async function deleteInventory(id) {
    if (!confirm("هل أنت متأكد من حذف هذا كتاب من المخزن؟")) return;
    try {
        const res = await fetch(`${API_BASE}/api/erp/inventory/${id}`, { method: "DELETE" });
        appState.erpData = await res.json();
        recordActivityLog("حذف كتاب من المخزن", id);
        renderERPTables();
    } catch (err) {
        console.error(err);
    }
}

async function adjustInventoryCount(id, delta) {
    const item = (appState.erpData.inventory || []).find(x => x.id === id);
    if (!item) return;
    item.count = Math.max(0, item.count + delta);
    if (item.count === 0) {
        item.status = "غير متوفر";
    } else if (item.count < 20) {
        item.status = "شارف على النفاد";
    } else {
        item.status = "متوفر";
    }
    try {
        const res = await fetch(`${API_BASE}/api/erp/inventory`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(item)
        });
        appState.erpData = await res.json();
        renderERPTables();
    } catch (err) {
        console.error(err);
    }
}

// ===================================================================
// LIVE STREAM MANAGEMENT - Multi-stream with self-hosted HLS
// ===================================================================

let hlsInstance = null;
let activeStreamsPoll = null;

function renderLiveStream() {
    const container = document.getElementById("liveVideoContainer");
    const badge = document.getElementById("liveStreamBadge");
    const viewerCount = document.getElementById("liveViewerCount");
    const streamsBadge = document.getElementById("activeStreamsBadge");
    if (!container) return;

    const ls = appState.liveStream || { active: false, title: "لا يوجد بث", hlsUrl: "" };
    const streamId = ls.id || "";

    if (ls.active) {
        badge.textContent = "🔴 بث مباشر الآن";
        badge.style.background = "rgba(244,63,94,0.15)";
        badge.style.borderColor = "var(--accent)";
        badge.style.color = "var(--accent)";
        const mockViewers = ls.viewerCount || Math.floor(Math.random() * 60) + 40;
        viewerCount.textContent = `👁️ ${mockViewers} مشاهدة`;

        const hlsUrl = ls.hlsUrl || (streamId ? `/hls/${streamId}/live.m3u8` : "/hls/live.m3u8");
        container.innerHTML = `
            <div style="position:relative; width:100%; height:100%; background:#000;">
                <video id="hlsVideo" controls style="width:100%; height:100%; border-radius:12px;" playsinline></video>
                <div class="video-bounce-watermark" style="position:absolute; top:12px; left:12px; font-size:0.65rem; color:rgba(255,255,255,0.5); pointer-events:none;">${USERS_INFO[appState.currentRole]?.name || ''} | ${new Date().toLocaleDateString('ar-EG')}</div>
                <div style="position:absolute; bottom:8px; left:50%; transform:translateX(-50%); background:rgba(0,0,0,0.7); border-radius:20px; padding:0.25rem 0.75rem; font-size:0.75rem; font-weight:700; color:var(--accent);">
                    🔴 ${ls.title || 'بث مباشر'}
                </div>
            </div>
        `;
        const video = document.getElementById("hlsVideo");
        if (video) {
            if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
            if (video.canPlayType("application/vnd.apple.mpegurl")) {
                video.src = hlsUrl;
            } else if (typeof Hls !== "undefined") {
                hlsInstance = new Hls({ enableWorker: false });
                hlsInstance.loadSource(hlsUrl);
                hlsInstance.attachMedia(video);
                hlsInstance.on(Hls.Events.MANIFEST_PARSED, () => video.play());
            }
        }
    } else {
        if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
        badge.textContent = "⚫ غير متاح حالياً";
        badge.style.background = "rgba(255,255,255,0.03)";
        badge.style.borderColor = "rgba(255,255,255,0.1)";
        badge.style.color = "var(--text-muted)";
        viewerCount.textContent = "👁️ 0 مشاهدة";
        container.innerHTML = `
            <div class="camera-lens" style="font-size:2.5rem;">📡</div>
            <div class="teacher-stream-mock">البث المباشر غير نشط حالياً</div>
            <div class="stream-screenshare-view" style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem;">
                ${appState.currentRole === 'teacher' || appState.currentRole === 'admin'
                    ? 'افتح <a href="broadcast.html" target="_blank" style="color:var(--accent);font-weight:700;">استوديو البث</a> لبدء بث مباشر'
                    : 'سيتم إشعارك عند بدء البث المباشر من المعلم'}
            </div>
        `;
    }

    // Poll active streams count
    pollActiveStreams();
}

async function pollActiveStreams() {
    try {
        const res = await fetch(`${API_BASE}/api/live-streams`);
        const streams = await res.json();
        const active = Array.isArray(streams) ? streams.filter(s => s && s.active) : [];
        const badge = document.getElementById("activeStreamsBadge");
        if (badge) {
            if (active.length > 0) {
                badge.textContent = `🔴 ${active.length} بث نشط`;
                badge.style.color = "#ef4444";
            } else {
                badge.textContent = "⚫ 0 بث نشط";
                badge.style.color = "var(--text-muted)";
            }
        }
    } catch(e) {}
}

/** Share live stream link to clipboard */
function shareLiveStream() {
    const baseUrl = window.location.protocol + '//' + window.location.host;
    const streamId = appState.liveStream?.id;
    const viewerUrl = streamId ? `${baseUrl}/live-view.html?id=${streamId}` : `${baseUrl}/live-view.html`;
    if (navigator.clipboard) {
        navigator.clipboard.writeText(viewerUrl).then(() => {
            alert('✅ تم نسخ رابط المشاهدة المباشرة!\n' + viewerUrl + '\n\nأرسل هذا الرابط للطلاب لمشاهدة البث.');
        });
    } else {
        alert('🔗 رابط المشاهدة المباشرة:\n' + viewerUrl + '\n\nانسخ هذا الرابط وأرسله للطلاب.');
    }
}

/** Copy current stream link */
function copyCurrentStreamLink() {
    shareLiveStream();
}

// ===================================================================

// ===================================================================
// FILE UPLOAD HELPERS
// ===================================================================

/**
 * Generic file upload to /api/upload.
 * Returns { url, name, size } on success, or null on failure.
 */
async function uploadFile(file, onProgress) {
    const formData = new FormData();
    formData.append("file", file);

    return new Promise((resolve) => {
        const xhr = new XMLHttpRequest();
        xhr.open("POST", `${API_BASE}/api/upload`);

        xhr.upload.onprogress = (e) => {
            if (e.lengthComputable && onProgress) {
                const pct = Math.round((e.loaded / e.total) * 100);
                onProgress(pct);
            }
        };

        xhr.onload = () => {
            if (xhr.status === 200) {
                try {
                    resolve(JSON.parse(xhr.responseText));
                } catch {
                    resolve(null);
                }
            } else {
                resolve(null);
            }
        };

        xhr.onerror = () => resolve(null);
        xhr.send(formData);
    });
}

/** Upload material file - updates the size field and shows progress */
async function uploadMaterialFile() {
    const fileInput = document.getElementById("materialFile");
    const file = fileInput?.files?.[0];
    if (!file) {
        alert("يرجى اختيار ملف أولاً.");
        return;
    }

    const progressWrapper = document.getElementById("materialUploadProgress");
    const bar = document.getElementById("materialUploadBar");
    const status = document.getElementById("materialUploadStatus");

    progressWrapper.style.display = "block";
    status.textContent = "⬆️ جاري الرفع...";
    bar.style.width = "0%";

    const result = await uploadFile(file, (pct) => {
        bar.style.width = `${pct}%`;
        status.textContent = `⬆️ ${pct}%`;
    });

    if (result) {
        status.textContent = `✅ تم الرفع بنجاح: ${result.name} (${result.size})`;
        bar.style.width = "100%";
        // Auto-fill name and size fields from upload
        const nameField = document.getElementById("materialName");
        const sizeField = document.getElementById("materialSize");
        if (nameField && !nameField.value) nameField.value = result.name;
        if (sizeField) sizeField.value = result.size;
        // Store the server URL in a data attribute for handleMaterialSubmit
        fileInput.dataset.uploadedUrl = result.url;
    } else {
        status.textContent = "❌ فشل الرفع. تأكد من تشغيل السيرفر وحجم الملف.";
        bar.style.width = "0%";
    }
}

/** Upload lesson video file - fills lessonVideoSource with the resulting URL */
async function uploadLessonVideo() {
    const fileInput = document.getElementById("lessonVideoFile");
    const file = fileInput?.files?.[0];
    if (!file) {
        alert("يرجى اختيار ملف فيديو أولاً.");
        return;
    }

    const statusEl = document.getElementById("lessonVideoUploadStatus");
    statusEl.textContent = "⬆️ جاري رفع الفيديو... (قد يستغرق وقتاً)";

    const result = await uploadFile(file, (pct) => {
        statusEl.textContent = `⬆️ ${pct}% - جاري الرفع...`;
    });

    if (result) {
        statusEl.textContent = `✅ تم الرفع: ${result.name} (${result.size})`;
        // Set the source field to the uploaded file URL
        const srcField = document.getElementById("lessonVideoSource");
        if (srcField) srcField.value = result.url;
    } else {
        statusEl.textContent = "❌ فشل رفع الفيديو. جرب رابط يوتيوب embed بدلاً من ذلك.";
    }
}

/* ==========================================================
   🌙 DARK MODE TOGGLE
   ========================================================== */
(function initDarkMode() {
    const toggle = document.getElementById('darkModeToggle');
    if (!toggle) return;

    const html = document.documentElement;
    const sunIcon = toggle.querySelector('.sun-icon');
    const moonIcon = toggle.querySelector('.moon-icon');

    function setTheme(theme) {
        if (theme === 'dark') {
            html.setAttribute('data-theme', 'dark');
            sunIcon.style.display = 'none';
            moonIcon.style.display = '';
            toggle.title = 'الوضع الفاتح';
            toggle.classList.add('active');
        } else {
            html.removeAttribute('data-theme');
            sunIcon.style.display = '';
            moonIcon.style.display = 'none';
            toggle.title = 'الوضع الداكن';
            toggle.classList.remove('active');
        }
        localStorage.setItem('theme', theme);
    }

    const saved = localStorage.getItem('theme');
    if (saved) {
        setTheme(saved);
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        setTheme('dark');
    }

    toggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        setTheme(current);
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
            setTheme(e.matches ? 'dark' : 'light');
        }
    });
})();
