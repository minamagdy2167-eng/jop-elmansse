// --- QUIZ ANALYTICS TAB ---
function renderQuizAnalyticsOverview() {
    const qCount = appState.quizzes.length;
    document.getElementById("qaScheduledCount").textContent = "1 اختبار";
    document.getElementById("qaActiveCount").textContent = "1 اختبار";
    document.getElementById("qaCompletedCount").textContent = `${qCount} اختبارات`;
    
    // Average score calculation
    let totalScore = 0;
    let count = 0;
    appState.submissions.forEach(s => {
        const parts = s.score.split(" / ");
        if (parts.length === 2) {
            totalScore += (parseInt(parts[0]) / parseInt(parts[1]));
            count++;
        }
    });
    const avg = count > 0 ? Math.round((totalScore / count) * 100) : 84;
    document.getElementById("qaAvgPassRate").textContent = `${avg}%`;
}

