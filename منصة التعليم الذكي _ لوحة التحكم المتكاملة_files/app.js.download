}

async function handleMaterialSubmit(e) {
    e.preventDefault();
    const l = appState.selectedLesson;
    if (!l) return;
    const name = document.getElementById("materialName").value;
    const type = document.getElementById("materialType").value;
    let size = document.getElementById("materialSize").value || "3.5 MB";

    const m = { id: "mat-" + Math.random().toString(36).substr(2,9), name, type, size };
    if (!l.materials) l.materials = [];
    l.materials.push(m);

    try {
        await fetch(`${API_BASE}/api/courses`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(appState.selectedSubject)
        });
    } catch {}

    recordActivityLog("رفع ملف مرفق للدرس", `${name} (${type.toUpperCase()})`);
    closeModal("materialModal");
    renderLessonMaterials(l);
    renderMaterialsGrid();
}

// CREATE QUIZ
function openCreateQuizModal(type = "subject") {
    document.getElementById("quizForm").reset();
    document.getElementById("quizTargetType").value = type;
    document.getElementById("questionsBuilderList").innerHTML = "";
    appState.quizBuilderQuestions = [];
    addQuestionToBuilder();
    openModal("quizModal");
}

function addQuestionToBuilder() {
    const list = document.getElementById("questionsBuilderList");
    const idx = appState.quizBuilderQuestions.length;
    const div = document.createElement("div");
    div.className = "question-builder-item";
    div.id = `builderQ-${idx}`;
    div.innerHTML = `
        <button type="button" class="btn-remove-q" onclick="removeQuestionFromBuilder(${idx})">حذف</button>
        <div class="form-group">
            <label>السؤال المنهجي ${idx+1}</label>
            <input type="text" class="form-input q-text-input" placeholder="اكتب صيغة السؤال التقييمي..." required>
        </div>
        <div class="choices-builder-list">
            <div class="form-group"><input type="text" class="form-input q-choice-input" placeholder="خيار أ" required></div>
            <div class="form-group"><input type="text" class="form-input q-choice-input" placeholder="خيار ب" required></div>
            <div class="form-group"><input type="text" class="form-input q-choice-input" placeholder="خيار ج" required></div>
            <div class="form-group"><input type="text" class="form-input q-choice-input" placeholder="خيار د" required></div>
        </div>
        <div class="form-group">
            <label>الخيار الصحيح:</label>
            <select class="form-input q-correct-select">
                <option value="0">خيار أ</option>
                <option value="1">خيار ب</option>
                <option value="2">خيار ج</option>
                <option value="3">خيار د</option>
            </select>
        </div>
    `;
    list.appendChild(div);
    appState.quizBuilderQuestions.push({ active: true });
}

function removeQuestionFromBuilder(idx) {
    const el = document.getElementById(`builderQ-${idx}`);
    if (el) {
        el.remove();
        appState.quizBuilderQuestions[idx].active = false;
    }
}

async function handleQuizSubmit(e) {
    e.preventDefault();
    const title = document.getElementById("quizTitle").value;
    const limit = parseInt(document.getElementById("quizTime").value);
    const type = document.getElementById("quizTargetType").value;
    const targetId = type === "subject" ? appState.selectedSubject.id : appState.selectedLesson.id;

    const list = document.getElementById("questionsBuilderList");
    const items = list.querySelectorAll(".question-builder-item");
    const questions = [];

    items.forEach(item => {
        const text = item.querySelector(".q-text-input").value;
        const choiceEls = item.querySelectorAll(".q-choice-input");
        const choices = Array.from(choiceEls).map(el => el.value);
        const correct = parseInt(item.querySelector(".q-correct-select").value);
        questions.push({ id: "q-" + Math.random().toString(36).substr(2,9), text, choices, correctAnswer: correct });
    });

    if (questions.length === 0) {
        alert("يجب إضافة سؤال واحد على الأقل.");
        return;
    }

    const quiz = { id: "quiz-" + Math.random().toString(36).substr(2,9), title, targetType: type, targetId, timeLimit: limit, questions };

    try {
        const res = await fetch(`${API_BASE}/api/quizzes`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(quiz)
        });
        appState.quizzes = await res.json();
    } catch {
        appState.quizzes.push(quiz);
    }

    recordActivityLog("إنشاء ونشر اختبار ذكي جديد", title);
    closeModal("quizModal");
    renderQuizzesGrid();
    if (appState.selectedLesson) renderLessonQuizzes(appState.selectedLesson);
}

// --- ADDITIONAL CRUD HANDLERS ---

async function deleteActiveCourse() {
    const c = appState.selectedSubject;
    if (!c) return;
    if (!confirm(`هل أنت متأكد من حذف المادة التعليمية بالكامل: ${c.name}؟`)) return;
    try {
        const res = await fetch(`${API_BASE}/api/courses/${c.id}`, { method: "DELETE" });
        appState.courses = await res.json();
        recordActivityLog("حذف مادة دراسية بالكامل", c.name);
        closeSubjectDetail();
        renderSubjectsGrid();
    } catch (err) {
        console.error(err);
    }
}

async function deleteChapter(chIdx) {
    const c = appState.selectedSubject;
    if (!c) return;
    const chName = c.chapters[chIdx].title;
    if (!confirm(`هل أنت متأكد من حذف الفصل الدراسي: ${chName} بجميع دروسه؟`)) return;
    
    c.chapters.splice(chIdx, 1);
    try {
        const res = await fetch(`${API_BASE}/api/courses`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(c)
        });
        appState.courses = await res.json();
        appState.selectedSubject = appState.courses.find(x => x.id === c.id);
        recordActivityLog("حذف فصل دراسي", `${chName} من مادة ${c.name}`);
        renderChaptersList();
        document.getElementById("emptyLessonState").style.display = "flex";
        document.getElementById("activeLessonContent").style.display = "none";
    } catch (err) {
        console.error(err);
    }
}

async function deleteActiveLesson() {
    const c = appState.selectedSubject;
    const l = appState.selectedLesson;
    if (!c || !l) return;
    if (!confirm(`هل أنت متأكد من حذف الدرس: ${l.title}؟`)) return;
    
    let found = false;
    c.chapters.forEach(ch => {
        const idx = ch.lessons.findIndex(less => less.id === l.id);
        if (idx > -1) {
            ch.lessons.splice(idx, 1);
            found = true;
        }
    });
    
    if (found) {
        try {
            const res = await fetch(`${API_BASE}/api/courses`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(c)
            });
            appState.courses = await res.json();
            appState.selectedSubject = appState.courses.find(x => x.id === c.id);
            appState.selectedLesson = null;
            recordActivityLog("حذف درس فيديو", `${l.title} من مادة ${c.name}`);
            renderChaptersList();
            document.getElementById("emptyLessonState").style.display = "flex";
            document.getElementById("activeLessonContent").style.display = "none";
        } catch (err) {
            console.error(err);
        }
    }
}

async function deleteMaterial(matId) {
    const c = appState.selectedSubject;
    const l = appState.selectedLesson;
    if (!c || !l || !l.materials) return;
    
    const idx = l.materials.findIndex(m => m.id === matId);
    if (idx > -1) {
        const matName = l.materials[idx].name;
        if (!confirm(`هل أنت متأكد من حذف المرفق الدراسي: ${matName}؟`)) return;
        
        l.materials.splice(idx, 1);
        try {
            const res = await fetch(`${API_BASE}/api/courses`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(c)
            });
            appState.courses = await res.json();
            appState.selectedSubject = appState.courses.find(x => x.id === c.id);
            c.chapters.forEach(ch => {
                const freshLesson = ch.lessons.find(less => less.id === l.id);
                if (freshLesson) appState.selectedLesson = freshLesson;
            });
            recordActivityLog("حذف ملف مرفق للدرس", matName);
            renderLessonMaterials(appState.selectedLesson);
            renderMaterialsGrid();
        } catch (err) {
            console.error(err);
        }
    }
}

async function deleteAttendanceRecord(name) {
    if (!confirm(`هل أنت متأكد من حذف سجل حضور الطالب: ${name}؟`)) return;
    try {
        const res = await fetch(`${API_BASE}/api/attendance/${encodeURIComponent(name)}`, { method: "DELETE" });
        appState.attendance = await res.json();
        recordActivityLog("حذف سجل حضور طالب", name);
        renderAttendanceTable();
    } catch (err) {
        console.error(err);
    }
}

