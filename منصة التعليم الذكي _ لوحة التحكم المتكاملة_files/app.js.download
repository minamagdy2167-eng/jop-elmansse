/**
 * Educational Platform Dashboard PRO (منصتي) - Fullstack Frontend script
 * Connects to C# ASP.NET Core backend Minimal APIs.
 */

// API Base Url (blank means current host)
const API_BASE = "";

// Global App State
let appState = {
    currentRole: "teacher",
    courses: [],
    quizzes: [],
    logs: [],
    submissions: [],
    attendance: [],
    watchHistory: [],
    erpData: {},
    liveStream: { active: false, url: "", title: "", mode: "self", hlsUrl: "/hls/live.m3u8" },
    activeTab: "dashboard",
    selectedSubject: null,
    selectedLesson: null,
    quizBuilderQuestions: []
};

// Roles mapping
const USERS_INFO = {
    teacher: { name: "أ. أحمد المصري", role: "معلم المادة", avatar: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=100" },
    assistant: { name: "المهندس خالد الحربي", role: "مساعد معلم", avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=100" },
    student: { name: "طالب: يوسف محمد", role: "طالب مقيد", avatar: "https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?auto=format&fit=crop&q=80&w=100" },
    admin: { name: "المهندس علي السعيد", role: "مدير النظام", avatar: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=100" }
};

// Initialize Application
document.addEventListener("DOMContentLoaded", () => {
    initUI();
    fetchDataFromServer();
    startSimulatedUpdates();
});

// Fetch all backend states
async function fetchDataFromServer() {
    try {
        const [coursesRes, quizzesRes, logsRes, subRes, attRes, watchRes, erpRes, liveStreamRes] = await Promise.all([
            fetch(`${API_BASE}/api/courses`).then(r => r.json()),
            fetch(`${API_BASE}/api/quizzes`).then(r => r.json()),
            fetch(`${API_BASE}/api/logs`).then(r => r.json()),
            fetch(`${API_BASE}/api/submissions`).then(r => r.json()),
            fetch(`${API_BASE}/api/attendance`).then(r => r.json()),
            fetch(`${API_BASE}/api/watch-tracking`).then(r => r.json()),
            fetch(`${API_BASE}/api/erp`).then(r => r.json()),
            fetch(`${API_BASE}/api/live-stream`).then(r => r.json())
        ]);

        appState.courses = coursesRes;
        appState.quizzes = quizzesRes;
        appState.logs = logsRes;
        appState.submissions = subRes;
        appState.attendance = attRes;
        appState.watchHistory = watchRes;
        appState.erpData = erpRes;
        appState.liveStream = liveStreamRes;

        renderAll();
    } catch (err) {
        console.error("Backend connection error:", err);
        alert("⚠️ عذراً، تعذر الاتصال بـ .NET Backend. تأكد من تشغيل السيرفر على المنفذ 5000.");
    }
}

// UI Event Wireup
function initUI() {
    // Sidebar toggler (desktop collapse)
    const sidebar = document.getElementById("sidebar");
    const sidebarToggle = document.getElementById("sidebarToggle");
    sidebarToggle.addEventListener("click", () => sidebar.classList.toggle("collapsed"));

    // Mobile hamburger button
    const mobileMenuBtn = document.getElementById("mobileMenuBtn");
    if (mobileMenuBtn) {
        mobileMenuBtn.addEventListener("click", () => {
            const isOpen = sidebar.classList.contains("mobile-open");
            if (isOpen) {
                closeMobileSidebar();
            } else {
                openMobileSidebar();
            }
        });
    }

    // Close sidebar on resize to desktop
    window.addEventListener("resize", () => {
        if (window.innerWidth > 768) {
            closeMobileSidebar();
        }
    });

    // Tab bindings
    document.querySelectorAll(".sidebar-nav .nav-item").forEach(item => {
        item.addEventListener("click", (e) => {
            e.preventDefault();
            const tabId = item.getAttribute("data-tab");
            switchTab(tabId);
        });
    });

    // Role switcher
    const roleSelector = document.getElementById("roleSelector");
    roleSelector.addEventListener("change", (e) => {
        setRole(e.target.value);
    });

    // Forms listeners
    document.getElementById("subjectForm").addEventListener("submit", handleSubjectSubmit);
    document.getElementById("chapterForm").addEventListener("submit", handleChapterSubmit);
    document.getElementById("lessonForm").addEventListener("submit", handleLessonSubmit);
    document.getElementById("materialForm").addEventListener("submit", handleMaterialSubmit);
    document.getElementById("quizForm").addEventListener("submit", handleQuizSubmit);
    document.getElementById("quizAnswersForm").addEventListener("submit", handleQuizAnswersSubmit);
    document.getElementById("staffForm").addEventListener("submit", handleStaffSubmit);
    document.getElementById("inventoryForm").addEventListener("submit", handleInventorySubmit);

    // Searches & Filters
    document.getElementById("subjectSearch").addEventListener("input", renderSubjectsGrid);
    document.getElementById("materialSearch").addEventListener("input", renderMaterialsGrid);
    document.getElementById("logsSearch").addEventListener("input", renderLogs);
    document.getElementById("logUserFilter").addEventListener("change", renderLogs);
    document.getElementById("watchSearchInput").addEventListener("input", renderWatchHistoryTable);

    setRole(appState.currentRole);
}

// Switch Roles
function setRole(role) {
    appState.currentRole = role;
    
    document.body.className = "";
    document.body.classList.add(`role-${role}`);

    if (role === "teacher" || role === "admin") {
        document.body.classList.add("can-edit");
    } else {
        document.body.classList.remove("can-edit");
    }

    const info = USERS_INFO[role];
    document.getElementById("sidebarAvatar").src = info.avatar;
    document.getElementById("sidebarUserName").textContent = info.name;
    document.getElementById("sidebarUserRole").textContent = info.role;
    
    document.getElementById("floatingRoleBadge").textContent = info.role;
    document.getElementById("welcomeTitle").textContent = `مرحباً بك مجدداً، ${info.name}!`;

    // Access control check
    if ((role === "student" || role === "assistant") && appState.activeTab === "logs") {
        switchTab("dashboard");
    }

    renderAll();
}

// Tabs Switcher
function switchTab(tabId) {
    if (tabId === "logs" && (appState.currentRole === "student" || appState.currentRole === "assistant")) {
        alert("⚠️ عذراً، لا تمتلك الصلاحية الكافية لعرض سجل التغييرات.");
        return;
    }

    appState.activeTab = tabId;
    
    document.querySelectorAll(".sidebar-nav .nav-item").forEach(item => {
        if (item.getAttribute("data-tab") === tabId) item.classList.add("active");
        else item.classList.remove("active");
    });

    document.querySelectorAll(".tab-content").forEach(tab => tab.classList.remove("active"));
    const targetTab = document.getElementById(`tab-${tabId}`);
    if (targetTab) targetTab.classList.add("active");

    // Close mobile sidebar after nav
    closeMobileSidebar();

    const titles = {
        dashboard: "الرئيسية ولوحة التحكم",
        subjects: "المواد والمناهج التعليمية",
        quizzes: "نظام الاختبارات والتقييم",
        materials: "المكتبة والملفات المرفقة",
        attendance: "📊 متابعة حضور وغياب الطلاب",
        "watch-tracking": "👁️ تتبع مشاهدات المحاضرات التفاعلي",
        progress: "📈 لوحة تقدم الطالب والمنحنيات",
        "learning-paths": "🎯 الخطط والمسارات الدراسية الذكية",
        "quiz-analytics": "📊 تحليلات الاختبارات ورؤى الفصول",
        "ai-tutor": "🤖 مساعد المعلم الذكي والتدريب 24/7",
        "live-stream": "📡 استوديو البث المباشر والأسئلة التفاعلية",
        erp: "🖥️ النظام المتكامل لإدارة الموارد والمخازن ERP",
        logs: "سجل العمليات ومتابعة المساعدين الأمني"
    };
    document.getElementById("pageTitle").textContent = titles[tabId] || "لوحة التحكم";

    if (tabId !== "subjects") {
        closeSubjectDetail();
    }
}

// Global Activity Logging proxying to backend
async function recordActivityLog(action, target) {
    const userProfile = USERS_INFO[appState.currentRole];
    const logItem = {
        user: userProfile.name,
        role: appState.currentRole,
        action: action,
        target: target,
        timestamp: new Date().toISOString(),
        fingerprint: "hash_" + Math.random().toString(36).substr(2, 9)
    };

    try {
        const res = await fetch(`${API_BASE}/api/logs`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(logItem)
        });
        appState.logs = await res.json();
        renderLogs();
        renderMiniLogs();
        renderUsersFilterDropdown();
    } catch {
        // Local fallback
        logItem.timestamp = new Date().toISOString();
        appState.logs.unshift(logItem);
        renderLogs();
        renderMiniLogs();
    }
}

// Rendering triggers
function renderAll() {
    renderStats();
    renderSubjectsGrid();
    renderQuizzesGrid();
    renderMaterialsGrid();
    renderLogs();
    renderMiniLogs();
    renderUsersFilterDropdown();
    renderSubmissionsTable();

    // New tabs
    renderAttendanceTable();
    renderInteractiveCalendar();
    renderWatchHistoryTable();
    renderSyllabusChecklist();
    renderLearningPath();
    renderSkillsRadar();
    renderQuizAnalyticsOverview();
    renderDifficultyAnalyzer();
    renderHistoricalComparison();
    renderERPTables();
    renderLiveStream();
}

function renderStats() {
    document.getElementById("statCoursesCount").textContent = appState.courses.length;
    document.getElementById("statQuizzesCount").textContent = appState.quizzes.length;
    
    let totalFiles = 0;
    appState.courses.forEach(c => {
        c.chapters.forEach(ch => {
            totalFiles += ch.lessons.reduce((acc, curr) => acc + (curr.materials ? curr.materials.length : 0), 0);
        });
    });
    document.getElementById("statFilesCount").textContent = totalFiles;
}

// --- SUBJECTS VIEW ---
function renderSubjectsGrid() {
    const grid = document.getElementById("subjectsGrid");
    const query = document.getElementById("subjectSearch").value.toLowerCase();
    grid.innerHTML = "";

    const filtered = appState.courses.filter(c => 
        c.name.toLowerCase().includes(query) || 
        c.desc.toLowerCase().includes(query)
    );

    if (filtered.length === 0) {
        grid.innerHTML = `<div class="empty-state" style="grid-column: 1/-1;">لا يوجد مواد متطابقة حالياً.</div>`;
        return;
    }

    filtered.forEach(course => {
        const card = document.createElement("div");
        card.className = "subject-card";
        card.onclick = () => viewSubjectDetail(course.id);
        let count = 0;
        course.chapters.forEach(ch => count += ch.lessons.length);

        card.innerHTML = `
            <div class="subject-card-image" style="background-image: url('${course.image || 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&q=80&w=400'}');">
                <span class="subject-tag">${course.category}</span>
            </div>
            <div class="subject-card-body">
                <h3 class="subject-title">${course.name}</h3>
                <p class="subject-desc">${course.desc}</p>
                <div class="subject-card-footer">
                    <span class="subject-price">${course.price} ج.م</span>
                    <div class="subject-stats-summary">
                        <span>📚 ${course.chapters.length} فصول</span>
                        <span>🎬 ${count} درس</span>
                    </div>
                </div>
            </div>
        `;
        grid.appendChild(card);
    });
}

function viewSubjectDetail(courseId) {
    const course = appState.courses.find(c => c.id === courseId);
    if (!course) return;

    appState.selectedSubject = course;
    appState.selectedLesson = null;

    document.getElementById("subjectsGrid").style.display = "none";
    document.getElementById("subjectDetailView").style.display = "block";

    document.getElementById("detailSubjectCategory").textContent = course.category;
    document.getElementById("detailSubjectName").textContent = course.name;
    document.getElementById("detailSubjectDesc").textContent = course.desc;
    document.getElementById("detailSubjectPrice").textContent = `${course.price} ج.م`;

    let lessonsCount = 0;
    course.chapters.forEach(ch => lessonsCount += ch.lessons.length);
    document.getElementById("detailSubjectChaptersCount").textContent = `${course.chapters.length} فصول`;
    document.getElementById("detailSubjectLessonsCount").textContent = `${lessonsCount} درس`;

    renderChaptersList();
    document.getElementById("emptyLessonState").style.display = "flex";
    document.getElementById("activeLessonContent").style.display = "none";
}

function closeSubjectDetail() {
    appState.selectedSubject = null;
    appState.selectedLesson = null;
    document.getElementById("subjectsGrid").style.display = "grid";
    document.getElementById("subjectDetailView").style.display = "none";
}

function renderChaptersList() {
    const list = document.getElementById("chaptersList");
    list.innerHTML = "";

    const course = appState.selectedSubject;
    if (!course || course.chapters.length === 0) {
        list.innerHTML = `<div class="empty-state">لا يوجد فصول حالياً.</div>`;
        return;
    }

    course.chapters.forEach((chapter, index) => {
        const item = document.createElement("div");
        item.className = "chapter-item";

        let lessonsHtml = "";
        if (chapter.lessons.length === 0) {
            lessonsHtml = `<div class="empty-state" style="font-size:0.7rem; padding:0.5rem;">لا يوجد دروس.</div>`;
        } else {
            chapter.lessons.forEach(l => {
                const isActive = appState.selectedLesson && appState.selectedLesson.id === l.id;
                lessonsHtml += `
                    <button class="lesson-item-btn ${isActive ? 'active' : ''}" onclick="selectLesson('${l.id}', ${index})">
                        🎬 ${l.title}
                    </button>
                `;
            });
        }

        item.innerHTML = `
            <div class="chapter-header-bar expanded" onclick="toggleChapterCollapse(this)">
                <span>📂 ${chapter.title}</span>
                <div class="chapter-actions editor-only" onclick="event.stopPropagation();" style="display:flex; gap:0.25rem; align-items:center;">
                    <button class="btn btn-sm btn-outline" style="padding:0.1rem 0.3rem; font-size:0.65rem;" onclick="openAddLessonModal(${index})">+ درس</button>
                    <button class="btn btn-sm btn-outline danger" style="padding:0.1rem 0.3rem; font-size:0.65rem;" onclick="deleteChapter(${index})">حذف</button>
                </div>
            </div>
            <div class="chapter-lessons-list">
                ${lessonsHtml}
            </div>
        `;
        list.appendChild(item);
    });
}

function toggleChapterCollapse(header) {
    header.classList.toggle("expanded");
}

// Secure Video components
function selectLesson(lessonId, chapterIndex) {
    const course = appState.selectedSubject;
    const chapter = course.chapters[chapterIndex];
    const lesson = chapter.lessons.find(l => l.id === lessonId);
    if (!lesson) return;

    appState.selectedLesson = lesson;
    renderChaptersList();

    document.getElementById("emptyLessonState").style.display = "none";
    document.getElementById("activeLessonContent").style.display = "block";

    document.getElementById("activeLessonTitle").textContent = lesson.title;
    document.getElementById("activeLessonDesc").textContent = lesson.desc;

    renderLessonMaterials(lesson);
    renderLessonQuizzes(lesson);

    const activeUser = USERS_INFO[appState.currentRole].name;
    document.getElementById("videoWatermark").textContent = `ID: ${activeUser} | ${new Date().toLocaleDateString('ar-EG')}`;

    const playerWrapper = document.getElementById("secureVideoWrapper");
    playerWrapper.innerHTML = "";

    const isYouTube = lesson.videoUrl.includes("youtube.com") || lesson.videoUrl.includes("youtu.be");

    if (isYouTube) {
        const frame = document.createElement("iframe");
        let embed = lesson.videoUrl;
        if (embed.includes("watch?v=")) {
            const vid = embed.split("watch?v=")[1].split("&")[0];
            embed = `https://www.youtube.com/embed/${vid}`;
        }
        frame.src = `${embed}?autoplay=0&controls=0&rel=0&modestbranding=1&disablekb=1&showinfo=0&fs=0`;
        frame.style.pointerEvents = "none";
        playerWrapper.appendChild(frame);

        const shield = document.createElement("div");
        shield.className = "player-shield";
        shield.innerHTML = `
            <div style="position: absolute; bottom: 8px; right: 8px; left: 8px; z-index: 20; display: flex; gap: 0.5rem; align-items: center; background-color: rgba(7, 10, 19, 0.9); padding: 0.4rem 0.8rem; border-radius: 6px;">
                <button class="btn btn-sm btn-primary" onclick="alert('تشغيل الفيديو الآمن')">▶ تشغيل</button>
                <div style="flex-grow:1; height:3px; background-color:rgba(255,255,255,0.15); border-radius:2px;">
                    <div style="width: 33%; height:100%; background-color:var(--secondary);"></div>
                </div>
                <span style="font-size:0.65rem; font-family:monospace; color:var(--text-muted);">05:22 / 18:40</span>
                <span class="secure-badge" style="font-size:0.6rem; border: 1px solid var(--success); padding: 0 4px; border-radius:3px;">محمي 🔒</span>
            </div>
        `;
        playerWrapper.appendChild(shield);

        shield.addEventListener("contextmenu", (e) => {
            e.preventDefault();
            alert("🔒 أمن المنصة: فحص عناصر الفيديو ونسخ الروابط المباشرة غير مصرح به.");
        });
    } else {
        const video = document.createElement("video");
        video.controls = true;
        video.controlsList = "nodownload nofullscreen";
        video.src = "blob:https://manssati-cdn.net/secure-stream/" + Math.random().toString(36).substr(2, 9);
        
        const placeholder = document.createElement("div");
        placeholder.className = "player-placeholder";
        placeholder.innerHTML = `
            <div class="text-center" style="padding:1.5rem;">
                <div style="font-size: 2rem; margin-bottom: 0.5rem;">🔒</div>
                <h5 style="color:#fff;">تم تشفير دفق الفيديو بنجاح (.NET CDN)</h5>
                <p style="font-size:0.7rem; color:var(--text-muted); font-family:monospace; margin-bottom:0.75rem;">${video.src}</p>
                <button class="btn btn-sm btn-primary" onclick="alert('بث تدفق المشغل المشفر')">بدء المشاهدة الحية</button>
            </div>
        `;
        playerWrapper.appendChild(video);
        playerWrapper.appendChild(placeholder);
        video.addEventListener("contextmenu", e => e.preventDefault());
    }

    initBouncingWatermark(playerWrapper);
}

function initBouncingWatermark(wrapper) {
    const activeUser = USERS_INFO[appState.currentRole].name;
    const badge = document.createElement("div");
    badge.className = "video-bounce-watermark";
    badge.textContent = `${activeUser} (مراقبة IP)`;
    wrapper.appendChild(badge);

    let x = 15;
    let y = 15;
    let dx = 1.2;
    let dy = 0.9;

    function animate() {
        if (!wrapper.contains(badge)) return;
        const wrapperRect = wrapper.getBoundingClientRect();
        const badgeRect = badge.getBoundingClientRect();
        const maxX = wrapperRect.width - badgeRect.width - 15;
        const maxY = wrapperRect.height - badgeRect.height - 15;

        if (x + dx > maxX || x + dx < 10) dx = -dx;
        if (y + dy > maxY || y + dy < 10) dy = -dy;

        x += dx;
        y += dy;

        badge.style.right = `${x}px`;
        badge.style.top = `${y}px`;
        requestAnimationFrame(animate);
    }
    setTimeout(animate, 600);
}

function renderLessonMaterials(lesson) {
    const list = document.getElementById("activeLessonMaterials");
    list.innerHTML = "";
    if (!lesson.materials || lesson.materials.length === 0) {
        list.innerHTML = `<div class="empty-state">لا يوجد مرفقات.</div>`;
        return;
    }
    const icons = { pdf: "📄", xlsx: "📊", docx: "📝", pptx: "🖼️" };
    lesson.materials.forEach(m => {
        const item = document.createElement("div");
        item.className = "material-item";
        const isEditor = appState.currentRole === "teacher" || appState.currentRole === "assistant" || appState.currentRole === "admin";
        const delBtn = isEditor ? `<button class="btn btn-sm btn-outline danger" style="margin-right:0.5rem;" onclick="deleteMaterial('${m.id}')">حذف</button>` : "";
        item.innerHTML = `
            <div class="material-info">
                <span class="file-icon">${icons[m.type] || "📁"}</span>
                <div>
                    <span class="file-title">${m.name}</span>
                    <div class="file-meta">حجم: ${m.size} | نوع: ${m.type.toUpperCase()}</div>
                </div>
            </div>
            <div style="display:flex; align-items:center;">
                <button class="btn-file-dl" onclick="alert('📥 جاري تنزيل الملف المرفق: ${m.name}')">تحميل</button>
                ${delBtn}
            </div>
        `;
        list.appendChild(item);
    });
}

function renderLessonQuizzes(lesson) {
    const list = document.getElementById("activeLessonQuizzes");
    list.innerHTML = "";
    const filtered = appState.quizzes.filter(q => q.targetType === "lesson" && q.targetId === lesson.id);
    if (filtered.length === 0) {
        list.innerHTML = `<div class="empty-state">لا يوجد اختبارات قصيرة.</div>`;
        return;
    }
    filtered.forEach(q => {
        const item = document.createElement("div");
        item.className = "quiz-item-bar";
        item.innerHTML = `
            <div class="quiz-bar-info">
                <span class="quiz-bar-title">${q.title}</span>
                <span class="quiz-bar-meta">⏱️ ${q.timeLimit} دقيقة | ❓ ${q.questions.length} أسئلة</span>
            </div>
            <button class="btn btn-sm btn-primary" onclick="startQuizTaking('${q.id}')">بدء</button>
        `;
        list.appendChild(item);
    });
}

// --- QUIZZES TAB ---
function renderQuizzesGrid() {
    const grid = document.getElementById("quizzesGrid");
    grid.innerHTML = "";
    if (appState.quizzes.length === 0) {
        grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1;">لا يوجد اختبارات حالياً.</div>`;
        return;
    }
    appState.quizzes.forEach(quiz => {
        const card = document.createElement("div");
        card.className = "quiz-card";
        card.innerHTML = `
            <div class="quiz-card-header">
                <span class="quiz-tag-badge">${quiz.targetType === "subject" ? 'المنهج كاملاً' : 'اختبار درس'}</span>
            </div>
            <h3 class="quiz-title">${quiz.title}</h3>
            <div class="quiz-details">
                <span>⏱️ الوقت: ${quiz.timeLimit} دقيقة</span>
                <span>❓ الأسئلة: ${quiz.questions.length}</span>
            </div>
            <div class="quiz-card-footer" style="display:flex; justify-content:space-between; width:100%; margin-top:0.5rem;">
                <button class="btn btn-sm btn-primary" onclick="startQuizTaking('${quiz.id}')">دخول</button>
                <button class="btn btn-sm btn-outline danger editor-only" onclick="deleteQuiz('${quiz.id}')">حذف</button>
            </div>
        `;
        grid.appendChild(card);
    });
}

async function deleteQuiz(id) {
    if (!confirm("هل أنت متأكد من الحذف؟")) return;
    try {
        const res = await fetch(`${API_BASE}/api/quizzes/${id}`, { method: "DELETE" });
        appState.quizzes = await res.json();
        recordActivityLog("حذف اختبار دراسي", id);
        renderQuizzesGrid();
    } catch {
        const index = appState.quizzes.findIndex(q => q.id === id);
        if (index > -1) {
            appState.quizzes.splice(index, 1);
            renderQuizzesGrid();
        }
    }
}

// --- QUIZ PLAYER (TIMER & ANTI-CHEAT) ---
let quizInterval = null;
let secondsRemaining = 0;
let violationsCount = 0;
let activeQuiz = null;

function startQuizTaking(quizId) {
    const quiz = appState.quizzes.find(q => q.id === quizId);
    if (!quiz || quiz.questions.length === 0) return;

    activeQuiz = quiz;
    violationsCount = 0;

    document.getElementById("quizPlayerModal").classList.add("active");
    document.getElementById("playerQuizTitle").textContent = quiz.title;
    document.getElementById("playerQuizTarget").textContent = quiz.targetType === "subject" ? "تقييم منهج" : "اختبار درس";

    const badge = document.getElementById("cheatWarningCount");
    badge.style.display = "inline-block";
    badge.textContent = "مخالفات التنقل: 0 / 3";

    const container = document.getElementById("quizQuestionsRender");
    container.innerHTML = "";

    quiz.questions.forEach((q, qIndex) => {
        const div = document.createElement("div");
        div.className = "render-question-item";
        let choices = "";
        q.choices.forEach((c, cIndex) => {
            choices += `
                <label class="choice-option-label" onclick="highlightSelectedChoice(this)">
                    <input type="radio" name="question_${q.id}" value="${cIndex}" required>
                    <span>${c}</span>
                </label>
            `;
        });
        div.innerHTML = `
            <div class="render-q-text">س ${qIndex+1}: ${q.text}</div>
            <div class="render-choices-list">${choices}</div>
        `;
        container.appendChild(div);
    });

    secondsRemaining = quiz.timeLimit * 60;
    updateQuizTimer();

    if (quizInterval) clearInterval(quizInterval);
    quizInterval = setInterval(() => {
        secondsRemaining--;
        updateQuizTimer();
        if (secondsRemaining <= 0) {
            clearInterval(quizInterval);
            alert("⏰ انتهى الوقت المسموح!");
            autoSubmitQuiz();
        }
    }, 1000);

    window.addEventListener("blur", handleBlurCheat);
    document.addEventListener("visibilitychange", handleVisibilityCheat);
}

function updateQuizTimer() {
    const h = Math.floor(secondsRemaining / 3600);
    const m = Math.floor((secondsRemaining % 3600) / 60);
    const s = secondsRemaining % 60;
    const pad = (n) => n.toString().padStart(2, '0');
    document.getElementById("quizTimerDisplay").textContent = `${pad(h)}:${pad(m)}:${pad(s)}`;
}

function highlightSelectedChoice(label) {
    label.parentNode.querySelectorAll(".choice-option-label").forEach(el => el.classList.remove("selected"));
    label.classList.add("selected");
}

function handleBlurCheat() {
    if (!activeQuiz) return;
    violationsCount++;
    alertCheat();
}

function handleVisibilityCheat() {
    if (!activeQuiz) return;
    if (document.hidden) {
        violationsCount++;
        alertCheat();
    }
}

function alertCheat() {
    document.getElementById("cheatWarningCount").textContent = `مخالفات التنقل: ${violationsCount} / 3`;
    if (violationsCount >= 3) {
        alert("🚨 تم إلغاء الاختبار بسبب تخطي محاولات الخروج الآمن (3 مخالفات).");
        autoSubmitQuiz();
    } else {
        alert(`⚠️ تحذير: يمنع مغادرة شاشة التقييم! المخالفات المرصودة: ${violationsCount} من 3.`);
    }
}

function closeQuizTaking() {
    window.removeEventListener("blur", handleBlurCheat);
    document.removeEventListener("visibilitychange", handleVisibilityCheat);
    if (quizInterval) clearInterval(quizInterval);
    activeQuiz = null;
    document.getElementById("quizPlayerModal").classList.remove("active");
}

function cancelQuizTaking() {
    if (confirm("هل تريد الانسحاب؟")) closeQuizTaking();
}

async function handleQuizAnswersSubmit(e) {
    e.preventDefault();
    await saveQuizResults();
}

function autoSubmitQuiz() {
    saveQuizResults();
}

async function saveQuizResults() {
    if (!activeQuiz) return;
    const quiz = activeQuiz;
    const form = document.getElementById("quizAnswersForm");
    let correct = 0;

    quiz.questions.forEach(q => {
        const selected = form.querySelector(`input[name="question_${q.id}"]:checked`);
        if (selected && parseInt(selected.value) === q.correctAnswer) correct++;
    });

    const elapsed = (quiz.timeLimit * 60) - secondsRemaining;
    const timeStr = `${Math.floor(elapsed/60).toString().padStart(2,'0')}:${(elapsed%60).toString().padStart(2,'0')}`;

    const submission = {
        studentName: USERS_INFO[appState.currentRole].name,
        quizTitle: quiz.title,
        subjectName: quiz.targetType === "subject" ? "المنهج الدراسي" : "الدرس القصير",
        score: `${correct} / ${quiz.questions.length}`,
        timeSpent: timeStr,
        date: new Date().toISOString().split('T')[0],
        status: (correct / quiz.questions.length) >= 0.5 ? "ناجح" : "راسب"
    };

    try {
        const res = await fetch(`${API_BASE}/api/submissions`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(submission)
        });
        appState.submissions = await res.json();
    } catch {
        appState.submissions.unshift(submission);
    }

    alert(`🎉 تم تسليم الإجابة!\nالدرجة: ${submission.score}`);
    renderSubmissionsTable();
    closeQuizTaking();
}

function renderSubmissionsTable() {
    const tbody = document.getElementById("quizSubmissionsTable");
    if (!tbody) return;
    tbody.innerHTML = "";
    if (appState.submissions.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="text-center">لا توجد نتائج مسجلة.</td></tr>`;
        return;
    }
    appState.submissions.forEach(s => {
        const color = s.status === "ناجح" ? "var(--success)" : "var(--accent)";
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td><strong>${s.studentName}</strong></td>
            <td>${s.quizTitle}</td>
            <td>${s.subjectName}</td>
            <td style="font-weight:700; color:var(--secondary);">${s.score}</td>
            <td>${s.timeSpent}</td>
            <td>${s.date}</td>
            <td><span class="badge" style="border-color:${color}; color:${color};">${s.status}</span></td>
        `;
        tbody.appendChild(tr);
    });
}

// --- MATERIALS LIBRARY ---
function renderMaterialsGrid() {
    const grid = document.getElementById("materialsGrid");
    const query = document.getElementById("materialSearch").value.toLowerCase();
    grid.innerHTML = "";

    let list = [];
    appState.courses.forEach(c => {
        c.chapters.forEach(ch => {
            ch.lessons.forEach(l => {
                if (l.materials) {
                    l.materials.forEach(m => {
                        list.push({ ...m, cName: c.name, lName: l.title });
                    });
                }
            });
        });
    });

    const filtered = list.filter(m => m.name.toLowerCase().includes(query));
    if (filtered.length === 0) {
        grid.innerHTML = `<div class="empty-state" style="grid-column:1/-1;">لا يوجد ملفات.</div>`;
        return;
    }
    const icons = { pdf: "📄", xlsx: "📊", docx: "📝", pptx: "🖼️" };
    filtered.forEach(m => {
        const card = document.createElement("div");
        card.className = "material-card";
        card.innerHTML = `
            <div class="mat-card-icon">${icons[m.type] || "📁"}</div>
            <div class="mat-card-title">${m.name}</div>
            <div class="mat-card-meta">
                <div>المادة: ${m.cName}</div>
                <div style="font-size:0.65rem;">حجم: ${m.size}</div>
            </div>
            <button class="btn btn-sm btn-outline" style="margin-top:auto;" onclick="alert('تنزيل المادة: ${m.name}')">تحميل</button>
        `;
        grid.appendChild(card);
    });
}

// --- NEW DASHBOARDS (ATTENDANCE & ABSENCE) ---
function renderAttendanceTable() {
    const tbody = document.getElementById("attendanceTableBody");
    if (!tbody) return;
    tbody.innerHTML = "";

    if (appState.attendance.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center">سجل الحضور فارغ.</td></tr>`;
        return;
    }

    // Load students selection in attendance modal
    const studentSelect = document.getElementById("attStudentSelect");
    if (studentSelect) {
        studentSelect.innerHTML = "";
        const uniqueStudents = ["يوسف محمد", "كريم أحمد", "سارة عبد الرحمن", "خالد الحربي", "نور علي"];
        uniqueStudents.forEach(st => {
            const opt = document.createElement("option");
            opt.value = st;
            opt.textContent = st;
            studentSelect.appendChild(opt);
        });
    }

    appState.attendance.forEach((att, idx) => {
        const tr = document.createElement("tr");
        let badgeColor = "var(--success)";
        if (att.status === "غائب") badgeColor = "var(--accent)";
        if (att.status === "متأخر") badgeColor = "var(--warning)";

        tr.innerHTML = `
            <td><strong>${att.studentName}</strong></td>
            <td><code>${att.code}</code></td>
            <td><span class="badge" style="border-color:${badgeColor}; color:${badgeColor};">${att.status}</span></td>
            <td>${att.timeArrived || "-"}</td>
            <td>${att.status === "غائب" ? '⚠️ تم إرسال تنبيه SMS' : '✅ آمن'}</td>
            <td>
                <button class="btn btn-sm btn-outline editor-only" onclick="toggleAttendanceStatus(${idx})">تغيير الحالة</button>
                <button class="btn btn-sm btn-outline danger editor-only" onclick="deleteAttendanceRecord('${att.studentName}')">حذف</button>
            </td>
        `;
        tbody.appendChild(tr);
    });

    // Update attendance counts
    const presentRate = Math.round((appState.attendance.filter(a => a.status === "حاضر" || a.status === "متأخر").length / appState.attendance.length) * 100) || 100;
    document.getElementById("attendancePresentRate").textContent = `${presentRate}%`;
    document.getElementById("attendanceLateCount").textContent = `${appState.attendance.filter(a => a.status === "متأخر").length} طلاب`;
    document.getElementById("attendanceAbsentCount").textContent = `${appState.attendance.filter(a => a.status === "غائب").length} طلاب`;
}

async function toggleAttendanceStatus(index) {
    const att = appState.attendance[index];
    const statuses = ["حاضر", "غائب", "متأخر"];
    let nextIdx = (statuses.indexOf(att.status) + 1) % 3;
    att.status = statuses[nextIdx];
    att.timeArrived = att.status === "حاضر" ? "08:00 ص" : att.status === "متأخر" ? "08:45 ص" : "-";

    try {
        const res = await fetch(`${API_BASE}/api/attendance`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(att)
        });
        appState.attendance = await res.json();
    } catch {
        // Local update
    }
    renderAttendanceTable();
    renderInteractiveCalendar();
}

function renderInteractiveCalendar() {
    const calendar = document.getElementById("interactiveCalendar");
    if (!calendar) return;
    calendar.innerHTML = "";

    // Day headers
    const days = ["س", "ح", "ن", "ث", "ر", "خ", "ج"];
    days.forEach(d => {
        const dh = document.createElement("div");
        dh.className = "calendar-day-header";
        dh.textContent = d;
        calendar.appendChild(dh);
    });

    // 30 days grid simulation
    for (let i = 1; i <= 30; i++) {
        const cell = document.createElement("div");
        cell.className = "calendar-day-cell";
        cell.textContent = i;

        // Mock status mapping for dynamic visualization
        if (i % 7 === 1) cell.classList.add("late");
        else if (i % 7 === 4) cell.classList.add("absent");
        else if (i % 7 !== 0) cell.classList.add("present"); // Friday (0) is off

        calendar.appendChild(cell);
    }
}

function openAddAttendanceModal() {
    document.getElementById("attendanceForm").reset();
    document.getElementById("attTimeInput").value = "08:15 ص";
    openModal("attendanceModal");
}

async function handleAttendanceSubmit(e) {
    e.preventDefault();
    const student = document.getElementById("attStudentSelect").value;
    const status = document.getElementById("attStatusSelect").value;
    const time = document.getElementById("attTimeInput").value;

    const record = {
        studentName: student,
        code: "ST-" + Math.floor(Math.random() * 900 + 100),
        status: status.replace("🟢 ", "").replace("🔴 ", "").replace("🟡 ", ""),
        timeArrived: status.includes("غائب") ? "-" : time
    };

    try {
        const res = await fetch(`${API_BASE}/api/attendance`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(record)
        });
        appState.attendance = await res.json();
    } catch {
        appState.attendance.unshift(record);
    }

    recordActivityLog("تسجيل حضور طالب", `${student} - ${status}`);
    closeModal("attendanceModal");
    renderAttendanceTable();
    renderInteractiveCalendar();
}

// --- WATCH TRACKING TAB ---
function renderWatchHistoryTable() {
    const tbody = document.getElementById("watchTrackingTableBody");
    if (!tbody) return;
    tbody.innerHTML = "";

    const query = document.getElementById("watchSearchInput").value.toLowerCase();
    const filtered = appState.watchHistory.filter(w => 
        w.studentName.toLowerCase().includes(query) || 
        w.lectureTitle.toLowerCase().includes(query)
    );

    if (filtered.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="text-center">لا توجد سجلات مشاهدات متطابقة.</td></tr>`;
        return;
    }

    filtered.forEach(w => {
        const tr = document.createElement("tr");
        const safetyBadge = w.screenCaptureAttempts > 0 
            ? `<span class="badge" style="border-color:var(--accent); color:var(--accent);">⚠️ مخالف (${w.screenCaptureAttempts} محاولات)</span>` 
            : `<span class="badge" style="border-color:var(--success); color:var(--success);">✅ آمن</span>`;

        tr.innerHTML = `
            <td><strong>${w.studentName}</strong></td>
            <td>${w.lectureTitle}</td>
            <td>${w.durationWatched} دقيقة</td>
            <td>
                <div style="display:flex; align-items:center; gap:0.5rem; width:120px;">
                    <div style="flex-grow:1; height:4px; background-color:rgba(255,255,255,0.05); border-radius:2px;">
                        <div style="width:${w.completionPercent}%; height:100%; background-color:var(--primary);"></div>
                    </div>
                    <span>${w.completionPercent}%</span>
                </div>
            </td>
            <td>${w.pauseCount} مرات</td>
            <td>${new Date(w.lastActive).toLocaleDateString('ar-EG')}</td>
            <td>${safetyBadge}</td>
        `;
        tbody.appendChild(tr);
    });
}

// --- SYLLABUS PROGRESS CHECKLIST ---
function renderSyllabusChecklist() {
    const container = document.getElementById("syllabusChecklist");
    if (!container) return;
    container.innerHTML = "";

    const checkpoints = [
        { label: "قانون أوم وتوصيل المقاومات", rate: 100 },
        { label: "قانونا كيرشوف للدوائر المغلقة", rate: 85 },
        { label: "تأثير المجال المغناطيسي لملف دائرى", rate: 40 },
        { label: "القوة المغناطيسية وعزم الازدواج", rate: 0 }
    ];

    checkpoints.forEach(c => {
        const div = document.createElement("div");
        const isDone = c.rate === 100;
        div.className = "syllabus-check-item";
        div.innerHTML = `
            <div class="syllabus-check-label">
                <span>${isDone ? '✅' : '⏳'}</span>
                <span>${c.label}</span>
            </div>
            <span style="font-weight:700; color:${isDone ? 'var(--success)' : 'var(--warning)'};">${c.rate}%</span>
        `;
        container.appendChild(div);
    });
}

