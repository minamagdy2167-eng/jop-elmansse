// --- PREMIUM MODULES (AI TUTOR & LIVE STREAM) ---
async function handleAITutorSubmit(e) {
    e.preventDefault();
    const inputEl = document.getElementById("aiTutorInput");
    const val = inputEl.value.trim();
    if (!val) return;

    inputEl.value = "";

    // Append student prompt to chat
    appendTutorMessage(val, false);

    // Call .NET AI chat api (simulated fallback available)
    try {
        const res = await fetch(`${API_BASE}/api/ai-chat`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ prompt: val })
        });
        const data = await res.json();
        setTimeout(() => appendTutorMessage(data.response, true), 500);
    } catch {
        // Simulated local bot answers
        let reply = "أنا جاهز لمساعدتك! هل يمكنك توضيح السؤال بشكل أفضل أو تحديد المعادلة؟";
        if (val.includes("أوم")) {
            reply = "ينص قانون أوم على أن: فرق الجهد الكهربائي بين طرفي موصل معدني يتناسب طردياً مع شدة التيار المار فيه عند ثبوت درجة الحرارة. المعادلة الرياضية هي: V = I * R.";
        } else if (val.includes("مسألة")) {
            reply = "مسألة مولدة:\nاحسب المقاومة المكافئة لمقاومتين موصلتين على التوازي قيمتهما 6 أوم و 3 أوم.\nالحل:\n1/R = 1/6 + 1/3 = 1/6 + 2/6 = 3/6\nإذن R = 6/3 = 2 أوم.";
        }
        setTimeout(() => appendTutorMessage(reply, true), 800);
    }
}

function sendPromptToAITutor(text) {
    document.getElementById("aiTutorInput").value = text;
}

function appendTutorMessage(text, isBot) {
    const chat = document.getElementById("aiTutorMessages");
    if (!chat) return;
    const div = document.createElement("div");
    div.className = `ai-msg ${isBot ? 'bot' : ''}`;
    div.innerHTML = `
        <div class="bubble">${text.replace(/\n/g, "<br>")}</div>
        <span class="time">${isBot ? '🤖 مساعد ذكي' : '🎓 أنت'}</span>
    `;
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
}

// Live Stream
function handleLiveChatSubmit(e) {
    e.preventDefault();
    const input = document.getElementById("liveChatInput");
    const text = input.value.trim();
    if (!text) return;
    input.value = "";

    const user = USERS_INFO[appState.currentRole].name;
    appendLiveChatMessage(user, text);
}

function appendLiveChatMessage(user, text) {
    const list = document.getElementById("liveChatMessages");
    if (!list) return;
    const div = document.createElement("div");
    div.className = "live-chat-msg";
    div.innerHTML = `
        <strong class="live-chat-user">${user}:</strong>
        <span>${text}</span>
    `;
    list.appendChild(div);
    list.scrollTop = list.scrollHeight;
}

function createNewLivePoll() {
    const question = prompt("اكتب سؤال الاستطلاع السريع:");
    if (!question) return;
    
    const div = document.getElementById("livePollContainer");
    div.innerHTML = `
        <div style="font-size:0.85rem; font-weight:700; margin-bottom:0.5rem;">📊 استطلاع نشط: ${question}</div>
        <div class="live-poll-option" onclick="voteLivePoll(1, 65)">
            <div class="live-poll-fill" id="pollFill1" style="width: 0%"></div>
            <div class="live-poll-text-row">
                <span>نعم، مفهوم تماماً</span>
                <span id="pollPct1">0%</span>
            </div>
        </div>
        <div class="live-poll-option" style="margin-top:0.5rem;" onclick="voteLivePoll(2, 35)">
            <div class="live-poll-fill" id="pollFill2" style="width: 0%"></div>
            <div class="live-poll-text-row">
                <span>بحاجة لإعادة الشرح</span>
                <span id="pollPct2">0%</span>
            </div>
        </div>
    `;
}

function voteLivePoll(option, mockPct) {
    document.getElementById(`pollFill${option}`).style.width = `${mockPct}%`;
    document.getElementById(`pollPct${option}`).textContent = `${mockPct}%`;
    
    // Auto populate other option
    const otherOption = option === 1 ? 2 : 1;
    const otherPct = 100 - mockPct;
    document.getElementById(`pollFill${otherOption}`).style.width = `${otherPct}%`;
    document.getElementById(`pollPct${otherOption}`).textContent = `${otherPct}%`;

    recordActivityLog("تصويت استطلاع حي", `الخيار ${option}`);
}

// Simulated active updates (mock sockets for active feed chats)
function startSimulatedUpdates() {
    // Scroll chats mockup periodically
    setInterval(() => {
        if (appState.activeTab === "live-stream") {
            const users = ["محمد كامل", "أمل علي", "كريم السعدي", "حازم أحمد"];
            const texts = ["فرق الجهد ثابت بالتوازي صح؟", "الخط واضح جداً يا بشمهندس", "هل البث مسجل تلقائياً؟", "تطبيق ممتاز!"];
            const randomIdx = Math.floor(Math.random() * users.length);
            appendLiveChatMessage(users[randomIdx], texts[randomIdx]);
        }
    }, 8000);

    // Initial Live Poll creation
    setTimeout(() => {
        const container = document.getElementById("livePollContainer");
        if (container) {
            container.innerHTML = `
                <div style="font-size:0.85rem; font-weight:700; margin-bottom:0.5rem;">📊 استطلاع نشط: هل فهمت فكرة التوازي؟</div>
                <div class="live-poll-option" onclick="voteLivePoll(1, 80)">
                    <div class="live-poll-fill" id="pollFill1" style="width: 45%"></div>
                    <div class="live-poll-text-row">
                        <span>نعم، واضحة</span>
                        <span id="pollPct1">45%</span>
                    </div>
                </div>
                <div class="live-poll-option" style="margin-top:0.5rem;" onclick="voteLivePoll(2, 20)">
                    <div class="live-poll-fill" id="pollFill2" style="width: 15%"></div>
                    <div class="live-poll-text-row">
                        <span>بحاجة لتمرين آخر</span>
                        <span id="pollPct2">15%</span>
                    </div>
                </div>
            `;
        }
    }, 2000);
}

// --- ERP INTEGRATION TAB ---
function renderERPTables() {
    const hr = document.getElementById("erpHRTable");
    const inv = document.getElementById("erpInventoryTable");
    if (!hr || !inv) return;

    hr.innerHTML = "";
    inv.innerHTML = "";

    // Set general erp card stats
    if (appState.erpData) {
        if (document.getElementById("erpRevenue")) {
            document.getElementById("erpRevenue").textContent = appState.erpData.revenue || "0 ج.م";
        }
        if (document.getElementById("erpSalary")) {
            document.getElementById("erpSalary").textContent = appState.erpData.salary || "0 ج.م";
        }
        if (document.getElementById("erpStorage")) {
            document.getElementById("erpStorage").textContent = appState.erpData.storage || "0 جيجا";
        }
    }

    const hrData = appState.erpData.hr || [];
    const invData = appState.erpData.inventory || [];

    hrData.forEach(h => {
        const tr = document.createElement("tr");
        const isPaid = h.status === "تم الصرف";
        tr.innerHTML = `
            <td><strong>${h.name}</strong></td>
            <td>${h.job}</td>
            <td>${h.salary}</td>
            <td><span class="badge" style="border-color:${isPaid ? 'var(--success)' : 'var(--warning)'}; color:${isPaid ? 'var(--success)' : 'var(--warning)'};">${h.status}</span></td>
            <td class="editor-only">
                <button class="btn btn-sm btn-outline" style="padding:0.15rem 0.35rem; font-size:0.7rem;" onclick="toggleStaffPaid('${h.id}')">${isPaid ? 'تراجع' : 'صرف'}</button>
                <button class="btn btn-sm btn-outline" style="padding:0.15rem 0.35rem; font-size:0.7rem; margin-right:0.25rem;" onclick="openEditStaffModal('${h.id}')">تعديل</button>
                <button class="btn btn-sm btn-outline danger" style="padding:0.15rem 0.35rem; font-size:0.7rem; margin-right:0.25rem;" onclick="deleteStaff('${h.id}')">حذف</button>
            </td>
        `;
        hr.appendChild(tr);
    });

    invData.forEach(i => {
        const tr = document.createElement("tr");
        const low = i.status.includes("شارف") || i.status.includes("نفاد");
        const out = i.status.includes("غير متوفر");
        let badgeColor = "var(--success)";
        if (low) badgeColor = "var(--warning)";
        if (out) badgeColor = "var(--accent)";

        tr.innerHTML = `
            <td><strong>${i.item}</strong></td>
            <td>${i.count} نسخة</td>
            <td>${i.price}</td>
            <td><span class="badge" style="border-color:${badgeColor}; color:${badgeColor};">${i.status}</span></td>
            <td class="editor-only">
                <button class="btn btn-sm btn-outline" style="padding:0.15rem 0.35rem; font-size:0.7rem;" onclick="adjustInventoryCount('${i.id}', 10)">+10</button>
                <button class="btn btn-sm btn-outline" style="padding:0.15rem 0.35rem; font-size:0.7rem; margin-right:0.25rem;" onclick="adjustInventoryCount('${i.id}', -10)">-10</button>
                <button class="btn btn-sm btn-outline" style="padding:0.15rem 0.35rem; font-size:0.7rem; margin-right:0.25rem;" onclick="openEditInventoryModal('${i.id}')">تعديل</button>
                <button class="btn btn-sm btn-outline danger" style="padding:0.15rem 0.35rem; font-size:0.7rem; margin-right:0.25rem;" onclick="deleteInventory('${i.id}')">حذف</button>
            </td>
        `;
        inv.appendChild(tr);
    });
}

// --- EXCEL REPORT EXPORTS ---
function exportTableToExcel(tableId, filename) {
    const table = document.getElementById(tableId);
    if (!table) {
        alert("⚠️ لم يتم العثور على جدول البيانات المعني للتصدير.");
        return;
    }

    let csvContent = "\uFEFF"; // UTF-8 BOM for Arabic support in Excel
    const rows = table.querySelectorAll("tr");

    rows.forEach(row => {
        const cols = row.querySelectorAll("th, td");
        const rowData = Array.from(cols).map(c => {
            // Clean up html tags, trim, and escape comma/quotes
            let val = c.innerText.replace(/"/g, '""');
            return `"${val}"`;
        }).join(",");
        csvContent += rowData + "\r\n";
    });

    const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.setAttribute("download", `${filename}_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    recordActivityLog("تصدير تقرير Excel", filename);
}

// --- LOGS TAB UTILS ---
function renderLogs() {
    const tbody = document.getElementById("auditLogsTable");
    if (!tbody) return;
    tbody.innerHTML = "";

    const query = document.getElementById("logsSearch").value.toLowerCase();
    const filter = document.getElementById("logUserFilter").value;

    const filtered = appState.logs.filter(l => {
        const matchesQuery = l.user.toLowerCase().includes(query) || l.action.toLowerCase().includes(query) || l.target.toLowerCase().includes(query);
        const matchesUser = filter === "" || l.user === filter;
        return matchesQuery && matchesUser;
    });

    if (filtered.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center">السجل فارغ.</td></tr>`;
        return;
    }

    filtered.forEach(log => {
        const tr = document.createElement("tr");
        const date = new Date(log.timestamp).toLocaleString('ar-EG');
        const roleText = log.role === "teacher" ? "👨‍🏫 معلم" : log.role === "assistant" ? "🧑‍💻 مساعد" : "🔑 مدير";
        const color = log.role === "teacher" ? "var(--primary)" : log.role === "assistant" ? "var(--secondary)" : "var(--accent)";

        tr.innerHTML = `
            <td><strong>${log.user}</strong></td>
            <td><span style="color:${color}; font-weight:700;">${roleText}</span></td>
            <td>${log.action}</td>
            <td style="color:var(--text-muted);">${log.target}</td>
            <td>${date}</td>
            <td><code style="font-size:0.7rem; color:var(--secondary);">${log.fingerprint}</code></td>
        `;
        tbody.appendChild(tr);
    });
}

function renderMiniLogs() {
    const list = document.getElementById("miniLogList");
    if (!list) return;
    list.innerHTML = "";

    const assistantLogs = appState.logs.filter(l => l.role === "assistant").slice(0, 4);
    if (assistantLogs.length === 0) {
        list.innerHTML = `<div class="empty-state">لا يوجد نشاطات للمساعدين حالياً.</div>`;
        return;
    }

    assistantLogs.forEach(log => {
        const div = document.createElement("div");
        div.className = "mini-log-item";
        div.innerHTML = `
            <div class="log-user-row">
                <span class="log-user-name">${log.user}</span>
                <span class="log-timestamp">قبل قليل</span>
            </div>
            <div>${log.action} : <span style="color:var(--text-muted);">${log.target}</span></div>
        `;
        list.appendChild(div);
    });
}

function renderUsersFilterDropdown() {
    const select = document.getElementById("logUserFilter");
    if (!select) return;
    select.innerHTML = `<option value="">كل المستخدمين</option>`;
    const users = [...new Set(appState.logs.map(l => l.user))];
    users.forEach(u => {
        const opt = document.createElement("option");
        opt.value = u;
        opt.textContent = u;
        select.appendChild(opt);
    });
}

async function clearLogs() {
    if (!confirm("هل تريد تصفير السجل؟")) return;
    try {
        await fetch(`${API_BASE}/api/logs`, { method: "DELETE" });
        appState.logs = [];
    } catch {
        appState.logs = [];
    }
    recordActivityLog("تصفير سجل العمليات المساعدين", "كل الأجهزة");
    renderLogs();
    renderMiniLogs();
}

// --- MODALS HELPER ---
function openModal(id) {
    document.getElementById(id).classList.add("active");
}

function closeModal(id) {
    document.getElementById(id).classList.remove("active");
}

// --- MOBILE SIDEBAR CONTROLS ---
function openMobileSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("mobileSidebarOverlay");
    if (sidebar) sidebar.classList.add("mobile-open");
    if (overlay) overlay.classList.add("active");
    document.body.style.overflow = "hidden";
}

function closeMobileSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("mobileSidebarOverlay");
    if (sidebar) sidebar.classList.remove("mobile-open");
    if (overlay) overlay.classList.remove("active");
    document.body.style.overflow = "";
}

// --- FORMS BINDINGS ---
function openAddSubjectModal() {
    document.getElementById("subjectForm").reset();
    document.getElementById("editSubjectId").value = "";
    document.getElementById("subjectModalTitle").textContent = "إضافة مادة جديدة";
    openModal("subjectModal");
}

function openEditSubjectModal() {
    const c = appState.selectedSubject;
    if (!c) return;
    document.getElementById("editSubjectId").value = c.id;
    document.getElementById("subjectName").value = c.name;
    document.getElementById("subjectCategory").value = c.category;
    document.getElementById("subjectDesc").value = c.desc;
    document.getElementById("subjectPrice").value = c.price;
    document.getElementById("subjectImage").value = c.image || "";
    document.getElementById("subjectModalTitle").textContent = "تعديل المادة الدراسية";
    openModal("subjectModal");
}

async function handleSubjectSubmit(e) {
    e.preventDefault();
    const id = document.getElementById("editSubjectId").value;
    const name = document.getElementById("subjectName").value;
    const cat = document.getElementById("subjectCategory").value;
    const desc = document.getElementById("subjectDesc").value;
    const price = parseFloat(document.getElementById("subjectPrice").value);
    const img = document.getElementById("subjectImage").value || "https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&q=80&w=400";

    const item = { id: id || "subject-" + Math.random().toString(36).substr(2,9), name, category: cat, desc, price, image: img, chapters: [] };

    try {
        const res = await fetch(`${API_BASE}/api/courses`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(item)
        });
        appState.courses = await res.json();
    } catch {
        if (id) {
            const idx = appState.courses.findIndex(c => c.id === id);
            if (idx > -1) {
                item.chapters = appState.courses[idx].chapters;
                appState.courses[idx] = item;
            }
        } else {
            appState.courses.push(item);
        }
    }

    recordActivityLog(id ? "تعديل مادة" : "إضافة مادة جديدة", name);
    closeModal("subjectModal");
    renderSubjectsGrid();
    if (appState.selectedSubject) viewSubjectDetail(appState.selectedSubject.id);
}

function openAddChapterModal() {
    document.getElementById("chapterForm").reset();
    openModal("chapterModal");
}

async function handleChapterSubmit(e) {
    e.preventDefault();
    const c = appState.selectedSubject;
    if (!c) return;
    const title = document.getElementById("chapterTitle").value;

    const chapter = { title: title, lessons: [] };
    c.chapters.push(chapter);

    try {
        await fetch(`${API_BASE}/api/courses`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(c)
        });
    } catch {}

    recordActivityLog("إضافة فصل دراسي", `${title} - مادة ${c.name}`);
    closeModal("chapterModal");
    renderChaptersList();
}

function openAddLessonModal(chIdx) {
    document.getElementById("lessonForm").reset();
    document.getElementById("editLessonId").value = "";
    document.getElementById("lessonChapterIndex").value = chIdx;
    document.getElementById("lessonModalTitle").textContent = "إضافة درس جديد";
    openModal("lessonModal");
}

function openEditLessonModal() {
    const l = appState.selectedLesson;
    if (!l) return;
    document.getElementById("editLessonId").value = l.id;
    document.getElementById("lessonTitle").value = l.title;
    document.getElementById("lessonVideoSource").value = l.videoUrl;
    document.getElementById("lessonDesc").value = l.desc;
    document.getElementById("lessonModalTitle").textContent = "تعديل الدرس";
    openModal("lessonModal");
}

async function handleLessonSubmit(e) {
    e.preventDefault();
    const c = appState.selectedSubject;
    const id = document.getElementById("editLessonId").value;
    const title = document.getElementById("lessonTitle").value;
    const url = document.getElementById("lessonVideoSource").value;
    const desc = document.getElementById("lessonDesc").value;
    const chIdx = parseInt(document.getElementById("lessonChapterIndex").value);

    let lesson = { id: id || "lesson-" + Math.random().toString(36).substr(2,9), title, videoUrl: url, desc, materials: [] };

    if (id) {
        c.chapters.forEach(ch => {
            const idx = ch.lessons.findIndex(l => l.id === id);
            if (idx > -1) {
                lesson.materials = ch.lessons[idx].materials;
                ch.lessons[idx] = lesson;
                appState.selectedLesson = lesson;
            }
        });
    } else {
        c.chapters[chIdx].lessons.push(lesson);
    }

    try {
        await fetch(`${API_BASE}/api/courses`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(c)
        });
    } catch {}

    recordActivityLog(id ? "تعديل درس فيديو" : "إضافة درس جديد للباب", title);
    closeModal("lessonModal");
    renderChaptersList();
    if (appState.selectedLesson) selectLesson(appState.selectedLesson.id, chIdx);
}

